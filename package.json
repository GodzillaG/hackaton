{
  "name": "scoliosis-screening-complex",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0 --port 3000",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0 --port 3000",
    "api": "uv --cache-dir /tmp/uv-cache run --no-sync python api_server.py --host 0.0.0.0 --port 5000",
    "test": "uv --cache-dir /tmp/uv-cache run --no-sync python -m unittest discover -s tests -p test_*.py"
  },
  "dependencies": {
    "next": "^15.5.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
